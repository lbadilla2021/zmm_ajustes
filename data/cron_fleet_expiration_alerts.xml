<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_send_fleet_expiration_alerts" model="ir.cron">
            <field name="name">Enviar avisos de vencimientos de flotilla</field>
            <field name="model_id" ref="fleet.model_fleet_vehicle"/>
            <field name="state">code</field>
            <field name="code">model.cron_send_expiration_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field
                name="nextcall"
                eval="(DateTime.now() + relativedelta(days=1)).replace(hour=8, minute=0, second=0).strftime('%Y-%m-%d %H:%M:%S')"
            />
            <field name="active">True</field>
        </record>
    </data>
</odoo>
