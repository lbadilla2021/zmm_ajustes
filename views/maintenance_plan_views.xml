<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_barca_maintenance_plan_tree" model="ir.ui.view">
        <field name="name">barca.maintenance.plan.tree</field>
        <field name="model">barca.maintenance.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="category_id"/>
                <field name="line_count" string="N° actividades"/>
                <field name="trigger_km"/>
                <field name="trigger_days"/>
                <field name="trigger_hours"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_barca_maintenance_plan_form" model="ir.ui.view">
        <field name="name">barca.maintenance.plan.form</field>
        <field name="model">barca.maintenance.plan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_generate_alerts"
                        type="object"
                        string="Generar avisos"
                        class="oe_highlight"
                        groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin"
                    />
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Nombre del plan"/></h1>
                    </div>

                    <group col="2">
                        <group>
                            <field name="category_id"/>
                            <field name="vehicle_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="line_count" string="N° actividades" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- ================================================ -->
                        <!-- TAB 1: ACTIVIDADES (el corazón del plan)          -->
                        <!-- ================================================ -->
                        <page string="Actividades" name="activities">
                            <field
                                name="plan_line_ids"
                                context="{
                                    'default_category_id': category_id
                                }"
                            >
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field
                                        name="technical_location_id"
                                        domain="[('category_id', '=?', parent.category_id)]"
                                        options="{'no_create': True}"
                                    />
                                    <field
                                        name="activity_id"
                                        domain="[
                                            ('category_id', '=?', parent.category_id),
                                            ('technical_location_id', '=?', technical_location_id)
                                        ]"
                                        options="{'no_create': True}"
                                    />
                                    <field
                                        name="intervention_type_id"
                                        options="{'no_create': True}"
                                    />
                                    <field name="estimated_duration" string="Duración (hrs)"/>
                                    <field name="note" optional="show"/>
                                    <!-- Campo oculto necesario para domain dinámico -->
                                    <field name="category_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>

                        <!-- ================================================ -->
                        <!-- TAB 2: TRIGGERS                                   -->
                        <!-- ================================================ -->
                        <page string="Triggers" name="triggers">
                            <group>
                                <field name="trigger_km"/>
                                <field name="trigger_days"/>
                                <field name="trigger_hours"/>
                            </group>
                        </page>

                        <!-- ================================================ -->
                        <!-- TAB 3: ADELANTOS                                  -->
                        <!-- ================================================ -->
                        <page string="Adelantos" name="advance">
                            <group>
                                <field name="advance_km"/>
                                <field name="advance_days"/>
                            </group>
                        </page>

                        <!-- ================================================ -->
                        <!-- TAB 4: MATERIALES / KITS                          -->
                        <!-- ================================================ -->
                        <page string="Materiales/Kits" name="materials">
                            <group>
                                <field
                                    name="kit_id"
                                    domain="[('active', '=', True), ('category_id', '=?', category_id)]"
                                />
                            </group>
                        </page>

                        <!-- ================================================ -->
                        <!-- TAB 5: SEGUIMIENTO BASE                           -->
                        <!-- ================================================ -->
                        <page string="Seguimiento base" name="tracking">
                            <group>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="last_execution_date"/>
                                <field name="last_execution_km"/>
                                <field name="last_execution_hours"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_maintenance_plan_search" model="ir.ui.view">
        <field name="name">barca.maintenance.plan.search</field>
        <field name="model">barca.maintenance.plan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="category_id"/>

                <filter name="active" string="Activos" domain="[('active', '=', True)]"/>

                <group expand="0" string="Agrupar por">
                    <filter
                        name="group_by_category"
                        string="Categoría"
                        domain="[]"
                        context="{'group_by': 'category_id'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <record id="action_barca_maintenance_plan" model="ir.actions.act_window">
        <field name="name">Planes de mantención</field>
        <field name="res_model">barca.maintenance.plan</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
