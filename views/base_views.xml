<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_barca_equipment" model="ir.actions.act_window">
        <field name="name">Equipos</field>
        <field name="res_model">maintenance.equipment</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <record id="action_barca_fleet_vehicle_odometer" model="ir.actions.act_window">
        <field name="name">Odómetros</field>
        <field name="res_model">fleet.vehicle.odometer</field>
        <field name="view_mode">list,kanban,form,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registre lecturas de odómetro para los vehículos.
            </p>
        </field>
    </record>

    <record id="action_barca_maintenance_report" model="ir.actions.act_window">
        <field name="name">Órdenes de Trabajo</field>
        <field name="res_model">maintenance.request</field>
        <field name="view_mode">kanban,list,form,calendar,pivot,graph,activity</field>
        <field name="context">{'search_default_active': True}</field>
    </record>


    <record id="action_barca_maintenance_request_report" model="ir.actions.act_window">
        <field name="name">Solicitudes de mantenimiento</field>
        <field name="res_model">maintenance.request</field>
        <field name="view_mode">graph,pivot,list,form</field>
        <field name="context">{'search_default_active': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Analice las solicitudes de mantenimiento por estado, equipo, responsable u otros criterios.
            </p>
        </field>
    </record>

    <record id="action_barca_maintenance_calendar" model="ir.actions.act_window">
        <field name="name">Calendario Mantenimiento</field>
        <field name="res_model">maintenance.request</field>
        <field name="view_mode">calendar,kanban,list,form,pivot,graph,activity</field>
        <field name="context">{'search_default_active': True, 'search_default_todo': True}</field>
    </record>

    <record id="action_barca_equipment_category" model="ir.actions.act_window">
        <field name="name">Categorías de equipos</field>
        <field name="res_model">maintenance.equipment.category</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <record id="action_barca_maintenance_team" model="ir.actions.act_window">
        <field name="name">Equipos de mantenimiento</field>
        <field name="res_model">maintenance.team</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <record id="view_barca_equipment_form_inherit_counters" model="ir.ui.view">
        <field name="name">maintenance.equipment.form.inherit.barca.counters</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook/page[@name='description']" position="before">
                <page string="Modelo" name="barca_model_tab">
                    <group>
                        <group string="MODELO">
                            <field name="fleet_vehicle_model_year"/>
                            <field name="fleet_vehicle_transmission"/>
                            <field name="fleet_vehicle_color"/>
                            <field name="fleet_vehicle_seats"/>
                            <field name="fleet_vehicle_doors"/>
                            <field name="fleet_vehicle_trailer_hook"/>
                        </group>
                        <group string="MOTOR">
                            <field name="fleet_vehicle_power_unit"/>
                            <field name="fleet_vehicle_power"/>
                            <field name="fleet_vehicle_range"/>
                            <field name="fleet_vehicle_fuel_type"/>
                            <field name="fleet_vehicle_co2"/>
                            <field name="fleet_vehicle_co2_standard"/>
                        </group>
                    </group>
                </page>
            </xpath>

            <xpath expr="//sheet/notebook" position="inside">
                <page string="Contadores" name="barca_counters">
                    <group>
                        <group string="Taller">
                            <field name="x_odometer_last_service"/>
                            <field name="x_hours_last_service"/>
                            <field name="x_last_entry_date"/>
                            <field name="x_last_exit_date"/>
                        </group>
                        <group string="Actual">
                            <field name="x_current_odometer"/>
                            <field name="x_current_operating_hours"/>
                        </group>
                    </group>
                </page>
                <page string="Documentación" name="barca_documentation">
                    <group>
                        <field name="x_doc_circulation_permit_expiry" readonly="1"/>
                        <field name="x_doc_technical_review_expiry" readonly="1"/>
                        <field name="x_doc_fuel_card" readonly="1"/>
                        <field name="x_doc_tag" readonly="1"/>
                        <field name="x_alert_days_before" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>


