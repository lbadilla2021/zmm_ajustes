<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_barca_technical_location_tree" model="ir.ui.view">
        <field name="name">barca.technical.location.tree</field>
        <field name="model">barca.technical.location</field>
        <field name="arch" type="xml">
            <list default_order="parent_id, name">
                <field name="code"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="parent_id"/>
                <field name="level"/>
                <field name="complete_name"/>
            </list>
        </field>
    </record>

    <record id="view_barca_technical_location_form" model="ir.ui.view">
        <field name="name">barca.technical.location.form</field>
        <field name="model">barca.technical.location</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="complete_name" readonly="1"/>
                    </group>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="category_id"/>
                            <field name="parent_id"/>
                            <field name="level"/>
                        </group>
                        <group>
                            <field name="kit_id"/>
                            <field name="estimated_useful_life"/>
                            <field name="reference_supplier_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                    <group string="Jerarquía">
                        <field name="child_ids" context="{'default_parent_id': id}" readonly="1">
                            <list>
                                <field name="code"/>
                                <field name="name"/>
                                <field name="category_id"/>
                                <field name="level"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_technical_location_search" model="ir.ui.view">
        <field name="name">barca.technical.location.search</field>
        <field name="model">barca.technical.location</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="category_id"/>
                <field name="parent_id"/>
                <field name="level"/>

                <filter name="level_1" string="Nivel 1" domain="[('level', '=', 1)]"/>
                <filter name="level_2" string="Nivel 2" domain="[('level', '=', 2)]"/>

                <group expand="0" string="Agrupar por">
                    <filter name="group_by_category" string="Categoría" domain="[]" context="{'group_by': 'category_id'}"/>
                    <filter name="group_by_level" string="Nivel" domain="[]" context="{'group_by': 'level'}"/>
                    <filter name="group_by_parent" string="Padre" domain="[]" context="{'group_by': 'parent_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_barca_technical_location" model="ir.actions.act_window">
        <field name="name">Ubicaciones técnicas</field>
        <field name="res_model">barca.technical.location</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
