<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_fleet_vehicle_related_equipment" model="ir.actions.act_window">
        <field name="name">Equipo de mantenimiento</field>
        <field name="res_model">maintenance.equipment</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('vehicle_id', '=', context.get('default_vehicle_id'))]</field>
        <field name="context">{'default_vehicle_id': context.get('default_vehicle_id')}</field>
    </record>


    <record id="view_fleet_vehicle_tree_inherit_mantencion_barca" model="ir.ui.view">
        <field name="name">fleet.vehicle.tree.inherit.mantencion.barca</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_vehicle_identifier" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_fleet_vehicle_form_inherit_mantencion_barca" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.inherit.mantencion.barca</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <!-- Smart button: equipo de mantenimiento vinculado -->
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button
                    name="%(zmm_ajustes.action_fleet_vehicle_related_equipment)d"
                    type="action"
                    class="oe_stat_button"
                    icon="fa-wrench"
                    groups="hr.group_hr_user,fleet.fleet_group_user"
                    context="{'default_vehicle_id': id, 'search_default_vehicle_id': id}"
                >
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Equipo</span>
                        <span class="o_stat_text">Mantenimiento</span>
                    </div>
                </button>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Mantención Barca">
                    <group string="Identificación interna">
                        <field name="x_vehicle_identifier" readonly="1"/>
                        <field name="x_internal_code"/>
                        <field name="x_engine_code"/>
                    </group>
                    <group string="Medidores">
                        <field name="x_odometer_last_service"/>
                        <field name="x_odometer_next_service"/>
                        <field name="x_operating_hours"/>
                        <field name="x_hours_last_service"/>
                    </group>
                    <group string="Taller">
                        <field name="x_last_entry_date"/>
                        <field name="x_last_exit_date"/>
                        <field name="x_downtime_total"/>
                    </group>
                    <group string="Documentación">
                        <field name="x_doc_circulation_permit_expiry"/>
                        <field name="x_doc_technical_review_expiry"/>
                        <field name="x_doc_padron"/>
                        <field name="x_doc_fuel_card"/>
                        <field name="x_doc_tag"/>
                        <field name="x_alert_days_before"/>
                    </group>
                    <group string="Notas">
                        <field name="x_maintenance_note"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
