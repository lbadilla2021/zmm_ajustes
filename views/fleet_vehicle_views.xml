<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fleet_vehicle_form_inherit_mantencion_barca" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.inherit.mantencion.barca</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='license_plate']/ancestor::h2[1]" position="after">
                <div class="o_row">
                    <label for="x_internal_code" class="me-2"/>
                    <field name="x_internal_code" readonly="1" nolabel="1"/>
                </div>
            </xpath>

            <xpath expr="//field[@name='future_driver_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='plan_to_change_car']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='order_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='manager_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='next_assignation_date']" position="after">
                <xpath expr="//field[@name='location']" position="move"/>
            </xpath>
            <xpath expr="//div[field[@name='odometer'] and field[@name='odometer_unit']]" position="after">
                <field name="x_operating_hours"/>
            </xpath>
            <xpath expr="//field[@name='vin_sn']" position="after">
                <field name="x_engine_code"/>
                <field name="x_has_insurance_contract" readonly="1"/>
            </xpath>

            <xpath expr="//page[@name='page_tax_info']" position="replace">
                <page string="Documentación" name="page_tax_info">
                    <group>
                        <field name="x_doc_circulation_permit_expiry"/>
                        <field name="x_doc_technical_review_expiry"/>
                        <field name="x_doc_fuel_card"/>
                        <field name="x_doc_tag"/>
                        <field name="x_alert_days_before"/>
                    </group>
                </page>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Taller" name="barca_workshop">
                    <group>
                        <field name="x_odometer_last_service"/>
                        <field name="x_hours_last_service"/>
                        <field name="x_last_entry_date"/>
                        <field name="x_last_exit_date"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_fleet_vehicle_form_inherit_hr_hide_mobility_card" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.inherit.hr.hide.mobility.card</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="hr_fleet.fleet_vehicle_view_form_inherit_hr"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='mobility_card']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
