<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_barca_intervention_type_tree" model="ir.ui.view">
        <field name="name">barca.intervention.type.tree</field>
        <field name="model">barca.intervention.type</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_barca_intervention_type_form" model="ir.ui.view">
        <field name="name">barca.intervention.type.form</field>
        <field name="model">barca.intervention.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_barca_intervention_type" model="ir.actions.act_window">
        <field name="name">Tipos de intervención</field>
        <field name="res_model">barca.intervention.type</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
