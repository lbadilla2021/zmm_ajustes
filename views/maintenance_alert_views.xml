<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_barca_maintenance_alert_tree" model="ir.ui.view">
        <field name="name">barca.maintenance.alert.tree</field>
        <field name="model">barca.maintenance.alert</field>
        <field name="arch" type="xml">
            <list default_order="create_date desc,id desc">
                <field name="name"/>
                <field name="alert_date"/>
                <field name="source_type"/>
                <field name="vehicle_id"/>
                <field name="priority"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_barca_maintenance_alert_form" model="ir.ui.view">
        <field name="name">barca.maintenance.alert.form</field>
        <field name="model">barca.maintenance.alert</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_take_for_evaluation"
                        string="Tomar para evaluación"
                        type="object"
                        class="oe_highlight"
                        groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin"
                        invisible="state != 'pending_evaluation'"
                    />
                    <button
                        name="action_reject"
                        string="Rechazar"
                        type="object"
                        groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin"
                        invisible="state not in ['pending_evaluation', 'approved']"
                    />
                    <button
                        name="action_create_maintenance_request"
                        string="Generar OT"
                        type="object"
                        class="oe_highlight"
                        groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin"
                        invisible="state != 'approved' or maintenance_request_id"
                    />
                    <button
                        name="action_view_maintenance_request"
                        string="Ver OT"
                        type="object"
                        groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin,zmm_ajustes.group_barca_ejecutor"
                        invisible="state != 'in_progress' or not maintenance_request_id"
                    />
                    <button
                        name="action_close"
                        string="Cerrar aviso"
                        type="object"
                        class="oe_highlight"
                        groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin"
                        invisible="state != 'in_progress'"
                    />
                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="pending_evaluation,approved,in_progress,rejected,closed"
                    />
                </header>
                <sheet>
                    <group col="2">
                        <group>
                            <field name="name" readonly="1"/>
                        </group>
                    </group>

                    <group string="Origen" col="2">
                        <group>
                            <field name="source_type"/>
                            <field name="source_reference"/>
                            <field name="source_request_id" readonly="1"/>
                            <field name="checklist_id" readonly="1"/>
                            <field name="pm_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="alert_date"/>
                        </group>
                    </group>

                    <group string="Activo afectado" col="2">
                        <group>
                            <field name="vehicle_id"/>
                            <field name="equipment_id"/>
                        </group>
                        <group>
                            <field name="odometer"/>
                            <field name="operating_hours"/>
                        </group>
                    </group>

                    <group string="Clasificación" col="2">
                        <group>
                            <field name="priority"/>
                        </group>
                    </group>

                    <!-- ================================================ -->
                    <!-- ACTIVIDADES DEL AVISO                             -->
                    <!-- ================================================ -->
                    <notebook>
                        <page string="Actividades" name="activities">
                            <field name="alert_line_ids">
                                <list editable="bottom" open_form_view="1">
                                    <field name="sequence" widget="handle"/>
                                    <field name="technical_location_id" readonly="1"/>
                                    <field name="intervention_type_id" readonly="1"/>
                                    <field name="activity_id" readonly="1"/>
                                    <field name="estimated_duration" string="Duración (hrs)" readonly="1"/>
                                    <field name="material_count" readonly="1"/>
                                    <field name="material_summary" readonly="1" optional="show"/>
                                    <field name="done"/>
                                    <field name="note" optional="show"/>
                                </list>
                                <form string="Actividad del aviso">
                                    <sheet>
                                        <group col="2">
                                            <group>
                                                <field name="technical_location_id" readonly="1"/>
                                                <field name="intervention_type_id" readonly="1"/>
                                                <field name="activity_id" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="estimated_duration" string="Duración (hrs)" readonly="1"/>
                                                <field name="done"/>
                                                <field name="note"/>
                                            </group>
                                        </group>
                                        <notebook>
                                            <page string="Materiales / Repuestos / Kits" name="materials">
                                                <field name="material_line_ids">
                                                    <list editable="bottom" open_form_view="1">
                                                        <field name="sequence" widget="handle"/>
                                                        <field name="product_id"/>
                                                        <field name="estimated_quantity"/>
                                                        <field
                                                            name="product_uom_id"
                                                            domain="[('category_id', '=', product_uom_category_id)]"
                                                        />
                                                        <field name="available_quantity" readonly="1"/>
                                                        <field name="product_uom_category_id" column_invisible="1"/>
                                                        <field name="note"/>
                                                    </list>

                                                    <form string="Material / Repuesto / Kit del aviso">
                                                        <sheet>
                                                            <group>
                                                                <field name="product_id"/>
                                                                <field
                                                                    name="product_uom_id"
                                                                    domain="[('category_id', '=', product_uom_category_id)]"
                                                                />
                                                                <field name="product_uom_category_id" invisible="1"/>
                                                                <field name="estimated_quantity"/>
                                                                <field name="available_quantity" readonly="1"/>
                                                                <field name="note"/>
                                                            </group>
                                                        </sheet>
                                                    </form>
                                                </field>
                                            </page>
                                        </notebook>
                                    </sheet>
                                </form>
                            </field>
                        </page>

                        <page string="Descripción y gestión" name="description">
                            <group string="Descripción">
                                <field name="description" nolabel="1"/>
                                <field name="origin_note" nolabel="1"/>
                            </group>

                            <group string="Gestión" col="2">
                                <group>
                                    <field name="evaluation_date"/>
                                    <field name="review_date"/>
                                    <field name="close_date"/>
                                </group>
                                <group>
                                    <field name="evaluated_by_id"/>
                                    <field name="approved_by_id"/>
                                    <field name="closed_by_id"/>
                                    <field name="maintenance_request_id" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_barca_maintenance_alert_search" model="ir.ui.view">
        <field name="name">barca.maintenance.alert.search</field>
        <field name="model">barca.maintenance.alert</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="source_type"/>
                <field name="state"/>
                <field name="priority"/>

                <filter name="pending_evaluation" string="Nuevo" domain="[('state', '=', 'pending_evaluation')]"/>
                <filter name="approved" string="En evaluación" domain="[('state', '=', 'approved')]"/>
                <filter name="in_progress" string="Con OT creada" domain="[('state', '=', 'in_progress')]"/>
                <filter name="rejected" string="Rechazado" domain="[('state', '=', 'rejected')]"/>
                <filter name="closed" string="Cerrado" domain="[('state', '=', 'closed')]"/>

                <group expand="0" string="Agrupar por">
                    <filter name="group_by_state" string="Estado" domain="[]" context="{'group_by': 'state'}"/>
                    <filter name="group_by_source_type" string="Origen" domain="[]" context="{'group_by': 'source_type'}"/>
                    <filter name="group_by_priority" string="Prioridad" domain="[]" context="{'group_by': 'priority'}"/>
                    <filter name="group_by_vehicle" string="Vehículo" domain="[]" context="{'group_by': 'vehicle_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_barca_maintenance_alert" model="ir.actions.act_window">
        <field name="name">Avisos</field>
        <field name="res_model">barca.maintenance.alert</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_barca_maintenance_alert"
        name="Avisos"
        parent="menu_barca_maintenance"
        action="action_barca_maintenance_alert"
        sequence="25"
        groups="zmm_ajustes.group_barca_conductor,zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_ejecutor,zmm_ajustes.group_barca_bodega,zmm_ajustes.group_barca_admin"
    />
</odoo>
