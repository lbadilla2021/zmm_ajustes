<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_barca_fleet_alert_rule_list" model="ir.ui.view">
        <field name="name">barca.fleet.alert.rule.list</field>
        <field name="model">barca.fleet.alert.rule</field>
        <field name="arch" type="xml">
            <list string="Alertas">
                <field name="rule"/>
                <field name="email_names"/>
            </list>
        </field>
    </record>

    <record id="view_barca_fleet_alert_rule_form" model="ir.ui.view">
        <field name="name">barca.fleet.alert.rule.form</field>
        <field name="model">barca.fleet.alert.rule</field>
        <field name="arch" type="xml">
            <form string="Alerta">
                <sheet>
                    <group>
                        <field name="rule"/>
                        <field name="email_names" placeholder="correo1@barca.cl, correo2@barca.cl"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_barca_fleet_alert_rule" model="ir.actions.act_window">
        <field name="name">Alertas</field>
        <field name="res_model">barca.fleet.alert.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_barca_fleet_alert_rule"
        name="Alertas"
        parent="menu_barca_configuraciones"
        action="action_barca_fleet_alert_rule"
        sequence="60"
        groups="zmm_ajustes.group_barca_admin"
    />

    <menuitem
        id="menu_fleet_alert_rule"
        name="Alertas"
        parent="fleet.fleet_configuration"
        action="action_barca_fleet_alert_rule"
        sequence="40"
        groups="fleet.fleet_group_manager,zmm_ajustes.group_barca_admin"
    />
</odoo>
