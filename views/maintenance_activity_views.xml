<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_barca_maintenance_activity_material_list" model="ir.ui.view">
        <field name="name">barca.maintenance.activity.material.list</field>
        <field name="model">barca.maintenance.activity.material</field>
        <field name="arch" type="xml">
            <list editable="bottom" open_form_view="1">
                <field name="sequence" widget="handle"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="product_uom_id"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_barca_maintenance_activity_material_form" model="ir.ui.view">
        <field name="name">barca.maintenance.activity.material.form</field>
        <field name="model">barca.maintenance.activity.material</field>
        <field name="arch" type="xml">
            <form string="Material / Repuesto / Kit propuesto">
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="quantity"/>
                        <field name="product_uom_id"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_barca_maintenance_activity_list" model="ir.ui.view">
        <field name="name">barca.maintenance.activity.list</field>
        <field name="model">barca.maintenance.activity</field>
        <field name="arch" type="xml">
            <list export_xlsx="1">
                <field name="code" optional="show"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="technical_location_id"/>
                <field name="technical_location_code" string="Código ubic. técnica"/>
                <field name="estimated_duration"/>
                <field name="material_count" readonly="1" optional="show"/>
                <field name="material_summary" readonly="1" optional="show"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_barca_maintenance_activity_form" model="ir.ui.view">
        <field name="name">barca.maintenance.activity.form</field>
        <field name="model">barca.maintenance.activity</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group col="2">
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="category_id"/>
                            <field
                                name="technical_location_id"
                                domain="[('category_id', '=?', category_id)]"
                            />
                            <field name="estimated_duration"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Instrucciones técnicas" name="technical_instructions">
                            <field name="note" nolabel="1"/>
                        </page>
                        <page string="Materiales / Repuestos / Kits" name="materials">
                            <separator string="Propuesta de productos para nuevos planes"/>
                            <group>
                                <field name="material_count" readonly="1"/>
                                <field name="material_summary" readonly="1"/>
                            </group>
                            <field name="material_template_line_ids">
                                <list editable="bottom" open_form_view="1">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field
                                        name="product_uom_id"
                                        domain="[('category_id', '=', product_uom_category_id)]"
                                    />
                                    <field name="product_uom_category_id" column_invisible="1"/>
                                    <field name="note"/>
                                </list>
                                <form string="Material / Repuesto / Kit estándar">
                                    <sheet>
                                        <group>
                                            <field name="product_id"/>
                                            <field
                                                name="product_uom_id"
                                                domain="[('category_id', '=', product_uom_category_id)]"
                                            />
                                            <field name="product_uom_category_id" invisible="1"/>
                                            <field name="quantity"/>
                                            <field name="note"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_barca_maintenance_activity_search" model="ir.ui.view">
        <field name="name">barca.maintenance.activity.search</field>
        <field name="model">barca.maintenance.activity</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="category_id"/>
                <field name="technical_location_id"/>

                <filter name="active" string="Activos" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Inactivos" domain="[('active', '=', False)]"/>

                <group expand="0" string="Agrupar por">
                    <filter
                        name="group_by_category"
                        string="Categoría"
                        domain="[]"
                        context="{'group_by': 'category_id'}"
                    />
                    <filter
                        name="group_by_location"
                        string="Ubicación técnica"
                        domain="[]"
                        context="{'group_by': 'technical_location_id'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <record id="action_barca_maintenance_activity" model="ir.actions.act_window">
        <field name="name">Actividades de mantención</field>
        <field name="res_model">barca.maintenance.activity</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>


</odoo>
