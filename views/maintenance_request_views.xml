<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_barca_maintenance_workorder_line_list" model="ir.ui.view">
        <field name="name">barca.maintenance.workorder.line.list</field>
        <field name="model">barca.maintenance.workorder.line</field>
        <field name="arch" type="xml">
            <list editable="bottom" open_form_view="1"
                  decoration-warning="barca_added_after_return == True">
                <field name="sequence" widget="handle"/>
                <field name="barca_added_after_return" column_invisible="1"/>
                <field name="barca_locked_for_executor" column_invisible="1"/>
                <field name="technical_location_id" required="1" readonly="barca_locked_for_executor"/>
                <field name="intervention_type_id" required="1" readonly="barca_locked_for_executor"/>
                <field name="activity_id" required="1" readonly="barca_locked_for_executor"/>
                <field name="estimated_duration" readonly="barca_locked_for_executor"/>
                <field name="state" readonly="1"/>
                <button name="action_start_line" string="Iniciar" type="object" class="btn-primary" display="always" invisible="state != 'pending' or barca_locked_for_executor"/>
                <button name="action_notify_line_open_form" string="Notificar" type="object" class="btn-primary" invisible="state != 'in_progress' or barca_locked_for_executor"/>
                <field name="material_count" readonly="1"/>
                <field name="material_summary" readonly="1"/>
                <field name="alert_line_id" readonly="1" optional="hide"/>
                <field name="alert_id" readonly="1" optional="hide"/>
                <field name="plan_line_id" readonly="1" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_barca_maintenance_workorder_line_material_list" model="ir.ui.view">
        <field name="name">barca.maintenance.workorder.line.material.list</field>
        <field name="model">barca.maintenance.workorder.line.material</field>
        <field name="arch" type="xml">
            <list editable="bottom" open_form_view="1">
                <field name="barca_locked_for_executor" column_invisible="1"/>
                <field name="sequence" widget="handle" readonly="barca_locked_for_executor"/>
                <field name="product_id" readonly="barca_locked_for_executor"/>
                <field
                    name="product_uom_id"
                    string="UdM"
                    domain="[('category_id', '=', product_uom_category_id)]"
                    readonly="barca_locked_for_executor"
                />
                <field name="product_uom_category_id" column_invisible="1"/>
                <field name="estimated_quantity" string="Estimado" readonly="barca_locked_for_executor"/>
                <field name="requested_quantity" string="Solicitado" readonly="barca_locked_for_executor"/>
                <field name="available_quantity" string="Serviteca" readonly="barca_locked_for_executor"/>
                <field name="consumed_quantity" string="Consumido" readonly="returned_quantity != 0 or barca_locked_for_executor"/>
                <field name="reserved_quantity" string="Reservado" readonly="1"/>
                <field name="returned_quantity" string="Devuelto" readonly="1"/>
                <field name="withdrawn_quantity" column_invisible="1"/>
                <field name="note" readonly="barca_locked_for_executor"/>
            </list>
        </field>
    </record>

    <record id="view_barca_maintenance_workorder_line_material_form" model="ir.ui.view">
        <field name="name">barca.maintenance.workorder.line.material.form</field>
        <field name="model">barca.maintenance.workorder.line.material</field>
        <field name="arch" type="xml">
            <form string="Material OT">
                <sheet>
                    <field name="barca_locked_for_executor" invisible="1"/>
                    <group>
                        <group string="Material">
                            <field name="sequence" readonly="barca_locked_for_executor"/>
                            <field name="product_id" readonly="barca_locked_for_executor"/>
                            <field
                                name="product_uom_id"
                                string="UdM"
                                domain="[('category_id', '=', product_uom_category_id)]"
                                readonly="barca_locked_for_executor"
                            />
                            <field name="product_uom_category_id" invisible="1"/>
                            <field name="note" readonly="barca_locked_for_executor"/>
                        </group>
                        <group string="Cantidades editables">
                            <field name="estimated_quantity" string="Estimado" readonly="barca_locked_for_executor"/>
                            <field name="requested_quantity" string="Solicitado" readonly="barca_locked_for_executor"/>
                            <field name="available_quantity" string="Serviteca" readonly="barca_locked_for_executor"/>
                            <field name="consumed_quantity" string="Consumido" readonly="returned_quantity != 0 or barca_locked_for_executor"/>
                        </group>
                        <group string="Cantidades calculadas">
                            <field name="reserved_quantity" string="Reservado" readonly="1"/>
                            <field name="returned_quantity" string="Devuelto" readonly="1"/>
                            <field name="withdrawn_quantity" invisible="1"/>
                        </group>
                    </group>
                    <group string="Trazabilidad">
                        <field name="workorder_line_id" readonly="1"/>
                        <field name="maintenance_request_id" readonly="1"/>
                        <field name="alert_line_material_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_barca_maintenance_workorder_line_form" model="ir.ui.view">
        <field name="name">barca.maintenance.workorder.line.form</field>
        <field name="model">barca.maintenance.workorder.line</field>
        <field name="arch" type="xml">
            <form string="Actividad de OT">
                <header>
                    <button name="action_start_line" string="Iniciar" type="object" class="btn-primary" invisible="state != 'pending' or barca_locked_for_executor"/>
                    <button name="action_barca_reserve_materials" string="Reservar materiales" type="object" class="btn-secondary" invisible="barca_locked_for_executor"/>
                    <button name="action_notify_line" string="Notificar" type="object" class="btn-primary" invisible="state != 'in_progress' or barca_locked_for_executor"/>
                    <button name="action_reset_to_pending" string="Reabrir a pendiente" type="object" groups="zmm_ajustes.group_barca_admin,zmm_ajustes.group_barca_programador" invisible="state not in ('in_progress', 'notified')"/>
                </header>
                <sheet>
                    <field name="barca_locked_for_executor" invisible="1"/>
                    <notebook>
                        <page string="Actividad" name="activity">
                            <group>
                                <group string="Datos técnicos">
                                    <field name="sequence" readonly="barca_locked_for_executor"/>
                                    <field name="technical_location_id" required="1" readonly="barca_locked_for_executor"/>
                                    <field name="intervention_type_id" required="1" readonly="barca_locked_for_executor"/>
                                    <field name="activity_id" required="1" readonly="barca_locked_for_executor"/>
                                    <field name="estimated_duration" readonly="barca_locked_for_executor"/>
                                    <field name="state" readonly="1"/>
                                    <field name="material_count" readonly="1"/>
                                    <field name="material_summary" readonly="1"/>
                                </group>
                                <group string="Trazabilidad">
                                    <field name="maintenance_request_id" readonly="1"/>
                                    <field name="alert_line_id" readonly="1"/>
                                    <field name="alert_id" readonly="1"/>
                                    <field name="plan_line_id" readonly="1"/>
                                </group>
                            </group>
                            <group string="Descripción y observaciones">
                                <field name="description" nolabel="1" readonly="barca_locked_for_executor"/>
                                <field name="note" nolabel="1" readonly="barca_locked_for_executor"/>
                            </group>
                        </page>
                        <page string="Materiales / Repuestos / Kits" name="materials">
                            <field
                                name="material_line_ids"
                                readonly="barca_locked_for_executor"
                                context="{
                                    'default_workorder_line_id': id,
                                    'list_view_ref': 'zmm_ajustes.view_barca_maintenance_workorder_line_material_list',
                                    'form_view_ref': 'zmm_ajustes.view_barca_maintenance_workorder_line_material_form'
                                }"
                            />
                        </page>
                        <page string="Notificación" name="notification">
                            <group>
                                <field name="notification_note" placeholder="Describa el trabajo realizado" readonly="barca_locked_for_executor"/>
                                <field name="result" readonly="barca_locked_for_executor"/>
                                <field name="notification_date" readonly="1"/>
                                <field name="notified_by_id" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!--
        Compatibilidad Odoo 18 Community:
        maintenance.hr_equipment_request_view_form es el formulario estándar vigente
        de maintenance.request y ya incluye <form><header>. Por eso el botón Barca
        se inserta dentro del header existente para no crear un segundo header.
    -->
    <record id="barca_maintenance_request_form_inherit" model="ir.ui.view">
        <field name="name">barca.maintenance.request.form.inherit</field>
        <field name="model">maintenance.request</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_request_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="placeholder">Orden de Trabajo</attribute>
                <attribute name="readonly">barca_locked_for_executor</attribute>
            </xpath>

            <xpath expr="//field[@name='request_date']" position="attributes">
                <attribute name="readonly">barca_locked_for_executor</attribute>
            </xpath>

            <xpath expr="//field[@name='equipment_id']" position="attributes">
                <attribute name="readonly">barca_locked_for_executor</attribute>
            </xpath>

            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="readonly">barca_locked_for_executor</attribute>
            </xpath>

            <xpath expr="//field[@name='stage_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//form/header" position="inside">
                <!-- Flujo de revisión Barca -->
                <button
                    name="action_barca_send_to_review"
                    string="Enviar a revisión"
                    type="object"
                    class="btn-primary"
                    groups="zmm_ajustes.group_barca_ejecutor,zmm_ajustes.group_barca_admin"
                    invisible="not barca_stage_is_in_progress"
                />
                <button
                    name="action_barca_close_total"
                    string="Cierre Total"
                    type="object"
                    class="btn-primary"
                    groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin"
                    invisible="not barca_stage_is_review"
                />
                <button
                    name="action_barca_close_partial"
                    string="Cierre Parcial"
                    type="object"
                    class="btn-secondary"
                    groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin"
                    invisible="not barca_stage_is_review"
                />
                <button
                    name="action_barca_return_to_progress"
                    string="Devolver a progreso"
                    type="object"
                    class="btn-secondary"
                    groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin"
                    invisible="not barca_stage_is_review"
                />
                <!-- Fase 6: botón cerrar materiales -->
                <button
                    name="action_barca_close_materials"
                    string="Cerrar materiales"
                    type="object"
                    class="btn-secondary"
                    invisible="barca_material_picking_id == False or barca_material_closed == True or barca_locked_for_executor"
                />
            </xpath>

            <xpath expr="//sheet/group[1]" position="inside">
                <field name="barca_alert_id" readonly="1" invisible="1"/>
                <field name="barca_activity_count" readonly="1" invisible="1"/>
                <field name="barca_total_activity_count" readonly="1" invisible="1"/>
                <field name="barca_notified_activity_count" readonly="1" invisible="1"/>
                <field name="barca_closed_activity_count" readonly="1" invisible="1"/>
                <field name="barca_all_activities_notified" readonly="1" invisible="1"/>
                <field name="barca_all_activities_closed" readonly="1" invisible="1"/>
                <field name="barca_stage_is_in_progress" readonly="1" invisible="1"/>
                <field name="barca_stage_is_review" readonly="1" invisible="1"/>
                <field name="barca_stage_is_partial_close" readonly="1" invisible="1"/>
                <field name="barca_stage_is_repaired" readonly="1" invisible="1"/>
                <field name="barca_locked_for_executor" readonly="1" invisible="1"/>
                <field name="barca_return_count" readonly="1" invisible="1"/>
            </xpath>

            <!-- Fase 5: sección de estado de reserva de materiales (visible si ya hubo reserva) -->
            <xpath expr="//sheet/notebook" position="before">
                <group>
                    <group
                        string="Reserva de materiales"
                        invisible="barca_material_picking_id == False and barca_material_state == 'pending_reservation'"
                    >
                        <field name="barca_material_state" readonly="1"/>
                        <field name="barca_pending_material" readonly="1"/>
                        <field name="barca_material_picking_id" readonly="1"/>
                    </group>

                    <!-- Modulo 3: revision -->
                    <group string="Revision"
                           invisible="barca_stage_is_in_progress and barca_return_count == 0">
                        <field name="barca_reviewer_id"
                               readonly="1"
                               invisible="not barca_reviewer_id"/>
                        <field name="barca_return_count" readonly="1"
                               invisible="barca_return_count == 0"/>
                        <field name="barca_return_reason"
                               readonly="not barca_stage_is_review"
                               invisible="barca_stage_is_in_progress and barca_return_count == 0"
                               groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin"/>
                        <button
                            name="action_barca_reopen_partial_to_review"
                            string="Reabrir a revision"
                            type="object"
                            class="btn-secondary"
                            groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin"
                            invisible="not barca_stage_is_partial_close"
                        />
                    </group>
                </group>

                <!-- Fase 6: sección entrega y cierre de materiales -->
                <group string="Inventario y cierre de materiales"
                       invisible="barca_material_withdrawn == False and barca_material_closed == False">
                    <group string="Entrega desde inventario">
                        <field name="barca_material_withdrawn" readonly="1"/>
                        <field name="barca_material_delivery_date" readonly="1"/>
                        <field name="barca_material_delivered_by_id" readonly="1"/>
                    </group>
                    <group string="Cierre">
                        <field name="barca_material_closed" readonly="1"/>
                        <field name="barca_material_closed_date" readonly="1"/>
                        <field name="barca_material_closed_by_id" readonly="1"/>
                    </group>
                    <group string="Costos estimados vs reales" col="2">
                        <field name="barca_currency_id" invisible="1"/>
                        <field name="barca_estimated_material_cost" readonly="1"
                               widget="monetary"
                               options="{'currency_field': 'barca_currency_id'}"/>
                        <field name="barca_real_material_cost" readonly="1"
                               widget="monetary"
                               options="{'currency_field': 'barca_currency_id'}"/>
                    </group>
                    <group string="Observación" col="1">
                        <field name="barca_material_note" nolabel="1" readonly="barca_locked_for_executor"/>
                    </group>
                </group>
            </xpath>

            <xpath expr="//sheet/notebook" position="inside">
                <page string="Actividades" name="barca_activities">
                    <field name="barca_activity_line_ids" readonly="barca_locked_for_executor" context="{'default_maintenance_request_id': id, 'form_view_ref': 'zmm_ajustes.view_barca_maintenance_workorder_line_form'}">
                        <list editable="bottom" open_form_view="1"
                              decoration-warning="barca_added_after_return == True">
                            <field name="sequence" widget="handle" readonly="parent.barca_locked_for_executor"/>
                            <field name="barca_added_after_return" column_invisible="1"/>
                            <field name="technical_location_id" required="1" readonly="parent.barca_locked_for_executor"/>
                            <field name="intervention_type_id" required="1" readonly="parent.barca_locked_for_executor"/>
                            <field name="activity_id" required="1" readonly="parent.barca_locked_for_executor"/>
                            <field name="estimated_duration" readonly="parent.barca_locked_for_executor"/>
                            <field name="state" readonly="1"/>
                            <button name="action_start_line" string="Iniciar" type="object" class="btn-primary" display="always" invisible="state != 'pending' or parent.barca_locked_for_executor"/>
                            <button name="action_notify_line_open_form" string="Notificar" type="object" class="btn-primary" invisible="state != 'in_progress' or parent.barca_locked_for_executor"/>
                            <field name="material_count" readonly="1"/>
                            <field name="material_summary" readonly="1"/>
                            <field name="alert_line_id" readonly="1" optional="hide"/>
                            <field name="alert_id" readonly="1" optional="hide"/>
                            <field name="plan_line_id" readonly="1" optional="hide"/>
                        </list>
                        <form string="Actividad de OT">
                            <header>
                                <button name="action_start_line" string="Iniciar" type="object" class="btn-primary" invisible="state != 'pending' or barca_locked_for_executor"/>
                                <button name="action_notify_line" string="Notificar" type="object" class="btn-primary" invisible="state != 'in_progress' or barca_locked_for_executor"/>
                                <button name="action_reset_to_pending" string="Reabrir a pendiente" type="object" groups="zmm_ajustes.group_barca_admin,zmm_ajustes.group_barca_programador" invisible="state not in ('in_progress', 'notified')"/>
                            </header>
                            <sheet>
                                <field name="barca_locked_for_executor" invisible="1"/>
                                <notebook>
                                    <page string="Actividad" name="activity">
                                        <group>
                                            <group string="Datos técnicos">
                                                <field name="sequence" readonly="barca_locked_for_executor"/>
                                                <field name="technical_location_id" required="1" readonly="barca_locked_for_executor"/>
                                                <field name="intervention_type_id" required="1" readonly="barca_locked_for_executor"/>
                                                <field name="activity_id" required="1" readonly="barca_locked_for_executor"/>
                                                <field name="estimated_duration" readonly="barca_locked_for_executor"/>
                                                <field name="state" readonly="1"/>
                                                <field name="material_count" readonly="1"/>
                                                <field name="material_summary" readonly="1"/>
                                            </group>
                                            <group string="Trazabilidad">
                                                <field name="maintenance_request_id" readonly="1"/>
                                                <field name="alert_line_id" readonly="1"/>
                                                <field name="alert_id" readonly="1"/>
                                                <field name="plan_line_id" readonly="1"/>
                                            </group>
                                        </group>
                                        <group string="Descripción y observaciones">
                                            <field name="description" nolabel="1" readonly="barca_locked_for_executor"/>
                                            <field name="note" nolabel="1" readonly="barca_locked_for_executor"/>
                                        </group>
                                    </page>
                                    <page string="Materiales / Repuestos / Kits" name="materials">
                                        <field name="material_line_ids" readonly="barca_locked_for_executor" context="{
                                            'default_workorder_line_id': id,
                                            'list_view_ref': 'zmm_ajustes.view_barca_maintenance_workorder_line_material_list',
                                            'form_view_ref': 'zmm_ajustes.view_barca_maintenance_workorder_line_material_form'
                                        }"/>
                                    </page>
                                    <page string="Notificación" name="notification">
                                        <group>
                                            <field name="notification_note" placeholder="Describa el trabajo realizado" readonly="barca_locked_for_executor"/>
                                            <field name="result" readonly="barca_locked_for_executor"/>
                                            <field name="notification_date" readonly="1"/>
                                            <field name="notified_by_id" readonly="1"/>
                                        </group>
                                    </page>
                                </notebook>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>

            <!-- Ocultar "Recurrente": la frecuencia la gestionan los planes de mantenimiento -->
            <xpath expr="//field[@name='recurring_maintenance']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Fecha programada: solo editable por programador y admin.
                 Se traspasa desde el aviso y no debe ser modificada por el jefe de taller.
                 En Odoo 18 no se puede usar user_has_groups() en atributos de vista:
                 se oculta el campo nativo y se muestran dos versiones según grupo. -->
            <xpath expr="//field[@name='schedule_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='schedule_date']" position="after">
                <!-- Versión editable: solo programador y admin -->
                <field name="schedule_date"
                       string="Fecha programada"
                       groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin"/>
                <!-- Versión readonly: resto de roles -->
                <field name="schedule_date"
                       string="Fecha programada"
                       readonly="1"
                       groups="zmm_ajustes.group_barca_ejecutor,zmm_ajustes.group_barca_bodega,zmm_ajustes.group_barca_conductor"/>
            </xpath>
        </field>
    </record>
</odoo>
