<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_barca_maintenance_checklist_tree" model="ir.ui.view">
        <field name="name">barca.maintenance.checklist.tree</field>
        <field name="model">barca.maintenance.checklist</field>
        <field name="arch" type="xml">
            <list default_order="checklist_date desc,id desc">
                <field name="checklist_date"/>
                <field name="name"/>
                <field name="requested_by_id"/>
                <field name="vehicle_id"/>
                <field name="checklist_type"/>
                <field name="vehicle_status"/>
                <field name="odometer"/>
                <field name="state"/>
                <field name="alert_id"/>
            </list>
        </field>
    </record>

    <record id="view_barca_maintenance_checklist_form" model="ir.ui.view">
        <field name="name">barca.maintenance.checklist.form</field>
        <field name="model">barca.maintenance.checklist</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_create_alert"
                        string="Generar Aviso"
                        type="object"
                        class="oe_highlight"
                        groups="zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_admin"
                        invisible="state != 'new'"
                    />
                    <button
                        name="action_close_no_notice"
                        string="Cerrar sin aviso"
                        type="object"
                        invisible="state != 'new'"
                    />
                    <button
                        name="action_cancel"
                        string="Cancelar"
                        type="object"
                        invisible="state != 'new'"
                    />
                    <button
                        name="action_view_alert"
                        string="Ver Aviso"
                        type="object"
                        invisible="not alert_id"
                    />
                    <field name="state" widget="statusbar" statusbar_visible="new,notice_created,closed_no_notice,cancelled"/>
                </header>
                <sheet>
                    <group col="2" string="Datos generales">
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="requested_by_id" readonly="state != 'new'"/>
                            <field name="checklist_date" readonly="1"/>
                            <field name="checklist_type" readonly="state != 'new'"/>
                            <field name="vehicle_status" readonly="state != 'new'"/>
                        </group>
                        <group>
                            <field name="vehicle_id" readonly="state != 'new'"/>
                            <field name="equipment_id" readonly="1"/>
                            <field name="fuel_load_time" widget="float_time" readonly="state != 'new'"/>
                            <field name="odometer" readonly="state != 'new'"/>
                            <field name="alert_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Planta y lugar detallado">
                        <field name="detailed_location" nolabel="1" readonly="state != 'new'"/>
                    </group>
                    <group string="Observaciones">
                        <field name="observations" nolabel="1" readonly="state != 'new'"/>
                    </group>
                    <notebook>
                        <page string="Puntos de control" name="control_points">
                            <field name="line_ids" readonly="state != 'new'">
                                <list editable="bottom" default_order="sequence,id" create="0" delete="0">
                                    <field name="sequence" widget="handle"/>
                                    <field name="control_type" readonly="1"/>
                                    <field name="control_item" readonly="1"/>
                                    <field name="yes"/>
                                    <field name="no"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_barca_maintenance_checklist_search" model="ir.ui.view">
        <field name="name">barca.maintenance.checklist.search</field>
        <field name="model">barca.maintenance.checklist</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="requested_by_id"/>
                <field name="vehicle_id"/>
                <field name="checklist_type"/>
                <field name="vehicle_status"/>
                <field name="state"/>
                <filter name="new" string="Nuevos" domain="[('state', '=', 'new')]"/>
                <filter name="notice_created" string="Con aviso generado" domain="[('state', '=', 'notice_created')]"/>
                <filter name="closed_no_notice" string="Cerrados sin aviso" domain="[('state', '=', 'closed_no_notice')]"/>
                <filter name="cancelled" string="Cancelados" domain="[('state', '=', 'cancelled')]"/>
                <filter name="vehicle_operativo" string="Vehículo operativo" domain="[('vehicle_status', '=', 'operativo')]"/>
                <filter name="vehicle_no_operativo" string="Vehículo no operativo" domain="[('vehicle_status', '=', 'no_operativo')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_by_type" string="Tipo de vehículo" domain="[]" context="{'group_by': 'checklist_type'}"/>
                    <filter name="group_by_requested_by" string="Solicitante" domain="[]" context="{'group_by': 'requested_by_id'}"/>
                    <filter name="group_by_vehicle" string="Equipo" domain="[]" context="{'group_by': 'vehicle_id'}"/>
                    <filter name="group_by_state" string="Estado" domain="[]" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_barca_maintenance_checklist" model="ir.actions.act_window">
        <field name="name">Checklists</field>
        <field name="res_model">barca.maintenance.checklist</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_barca_maintenance_checklist"
        name="Checklist"
        parent="menu_barca_maintenance"
        action="action_barca_maintenance_checklist"
        sequence="20"
        groups="zmm_ajustes.group_barca_conductor,zmm_ajustes.group_barca_programador,zmm_ajustes.group_barca_ejecutor,zmm_ajustes.group_barca_bodega,zmm_ajustes.group_barca_admin"
    />
</odoo>
