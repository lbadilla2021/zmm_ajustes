<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_barca_maintenance" model="ir.module.category">
        <field name="name">Mantención Barca</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_barca_conductor" model="res.groups">
        <field name="name">Barca / Conductor</field>
        <field name="category_id" ref="module_category_barca_maintenance"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_barca_programador" model="res.groups">
        <field name="name">Barca / Programador</field>
        <field name="category_id" ref="module_category_barca_maintenance"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_barca_ejecutor" model="res.groups">
        <field name="name">Barca / Ejecutor</field>
        <field name="category_id" ref="module_category_barca_maintenance"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_barca_bodega" model="res.groups">
        <field name="name">Barca / Bodega</field>
        <field name="category_id" ref="module_category_barca_maintenance"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_barca_admin" model="res.groups">
        <field name="name">Barca / Administrador</field>
        <field name="category_id" ref="module_category_barca_maintenance"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
